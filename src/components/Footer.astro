---
const today = new Date();
---

<footer>
  <div class="footer-inner">
    <p>© {today.getFullYear()} BrowserMan. Product notes, launch writing, and browser automation ideas.</p>
    <div class="footer-links">
      <a href="https://browserman.run">browserman.run</a>
      <a href="https://github.com/browserman-run/browserman-blog">GitHub</a>
      <a href="/rss.xml">RSS</a>
    </div>
  </div>
</footer>
<style>
  footer {
    padding: 2.5rem 1rem 4rem;
    color: rgb(var(--gray));
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(var(--gray), 0.18);
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }
  p {
    margin: 0;
    font-size: 0.95rem;
  }
  .footer-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .footer-links a {
    text-decoration: none;
    color: rgb(var(--gray));
  }
  .footer-links a:hover {
    color: rgb(var(--black));
  }
</style>
