---
import { PRODUCT_URL } from '../consts';
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="brand" aria-label="BrowserMan Blog home">
      <span class="brand__mark" aria-hidden="true">B</span>
      <span class="brand__name">
        <span class="brand__name-main">BrowserMan</span>
        <span class="brand__name-sub">Blog</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a href="/">Writing</a>
      <a href="/about/">About</a>
      <a href="/rss.xml" class="site-nav__rss" aria-label="RSS feed">RSS</a>
      <a href={PRODUCT_URL} class="site-nav__product">
        browserman.run <span aria-hidden="true">→</span>
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(120%) blur(6px);
    background: rgba(245, 241, 232, 0.85);
  }

  .site-header__inner {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--ink-1);
  }

  .brand:hover { color: var(--ink-1); }

  .brand__mark {
    font-family: var(--serif);
    font-style: italic;
    font-size: 2.4rem;
    line-height: 0.9;
    color: var(--ink-1);
    margin-top: -0.08em;
  }

  .brand__name {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }

  .brand__name-main {
    font-family: var(--sans);
    font-weight: 600;
    font-size: 0.98rem;
    letter-spacing: -0.01em;
  }

  .brand__name-sub {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-top: 2px;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 1.8rem;
  }

  .site-nav a {
    font-family: var(--sans);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--ink-2);
    text-decoration: none;
    transition: color 120ms var(--ease);
  }

  .site-nav a:hover { color: var(--ink-1); }

  .site-nav__rss {
    font-family: var(--mono) !important;
    font-size: 0.72rem !important;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3) !important;
  }

  .site-nav__product {
    color: var(--amber-deep) !important;
    font-weight: 600 !important;
  }

  .site-nav__product:hover { color: var(--ink-1) !important; }

  @media (max-width: 640px) {
    .site-header__inner { padding: 0.8rem 1rem; }
    .brand__name-sub { display: none; }
    .site-nav { gap: 1rem; }
    .site-nav a:not(.site-nav__product) { display: none; }
  }
</style>
