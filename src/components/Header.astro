---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <h2><a href="/">{SITE_TITLE}</a></h2>
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Posts</HeaderLink>
      <HeaderLink href="https://browserman.run" target="_blank" rel="noreferrer">BrowserMan</HeaderLink>
      <HeaderLink href="https://github.com/browserman-run/browserman-blog" target="_blank" rel="noreferrer">GitHub</HeaderLink>
    </div>
  </nav>
</header>
<style>
  header {
    margin: 0;
    padding: 0 1.25rem;
    background: rgba(255, 255, 255, 0.92);
    border-bottom: 1px solid rgba(var(--gray), 0.18);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 20;
  }
  h2 {
    margin: 0;
    font-size: 1rem;
    letter-spacing: 0.01em;
  }
  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 1100px;
    margin: 0 auto;
  }
  .internal-links {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    flex-wrap: wrap;
  }
  nav a {
    padding: 1rem 0.7rem;
    color: rgb(var(--black));
    border-bottom: 2px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }
  @media (max-width: 720px) {
    header {
      padding: 0 0.8rem;
    }
    nav {
      align-items: flex-start;
      flex-direction: column;
      padding: 0.35rem 0;
    }
    .internal-links {
      width: 100%;
      gap: 0;
    }
  }
</style>
