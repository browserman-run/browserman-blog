---
import { PRODUCT_URL } from '../consts';
import type { Lang } from '../lib/i18n';
import { getLocalizedAboutUrl, getLocalizedArchiveUrl, getLocalizedHomeUrl } from '../lib/i18n';
import { t } from '../i18n/ui';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang?: Lang;
  translationUrl?: string;
}

const { lang = 'en', translationUrl } = Astro.props;
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={getLocalizedHomeUrl(lang)} class="brand" aria-label="BrowserMan Blog home">
      <img class="brand__wordmark" src="/brand/wordmark.svg" alt="BrowserMan" width="140" height="28" />
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a href={getLocalizedArchiveUrl(lang)}>{t(lang, 'writing')}</a>
      <a href={getLocalizedAboutUrl(lang)}>{t(lang, 'about')}</a>
      <LanguageSwitcher lang={lang} translationUrl={translationUrl} />
      <a href={lang === 'zh' ? '/zh/rss.xml' : '/rss.xml'} class="site-nav__rss" aria-label="RSS feed">{t(lang, 'rss')}</a>
      <a href={PRODUCT_URL} class="site-nav__product">
        browserman.run <span aria-hidden="true">→</span>
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(120%) blur(6px);
    background: rgba(245, 241, 232, 0.85);
  }

  .site-header__inner {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--ink-1);
    flex: 0 0 auto;
  }

  .brand:hover { color: var(--ink-1); }

  .brand__wordmark {
    display: block;
    width: auto;
    height: 28px;
    max-width: 100%;
    border: 0;
    border-radius: 0;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 1.8rem;
  }

  .site-nav a {
    font-family: var(--sans);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--ink-2);
    text-decoration: none;
    transition: color 120ms var(--ease);
    white-space: nowrap;
  }

  .site-nav a:hover { color: var(--ink-1); }

  .site-nav__rss {
    font-family: var(--mono) !important;
    font-size: 0.72rem !important;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3) !important;
  }

  .site-nav__lang {
    color: var(--ink-1) !important;
  }

  .site-nav__product {
    color: var(--amber-deep) !important;
    font-weight: 600 !important;
  }

  .site-nav__product:hover { color: var(--ink-1) !important; }

  @media (max-width: 720px) {
    .site-header__inner { padding: 0.8rem 1rem; gap: 1rem; }
    .brand__wordmark { height: 24px; }
    .site-nav { gap: 1rem; }
    .site-nav a:not(.site-nav__product):not(.site-nav__lang) { display: none; }
  }

  @media (max-width: 420px) {
    .site-nav { gap: 0.75rem; }
    .site-nav a { font-size: 0.84rem; }
    .site-nav__product span { display: none; }
  }
</style>
