---
import { PRODUCT_URL } from '../consts';
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="brand" aria-label="BrowserMan Blog home">
      <svg
        class="brand__wordmark"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 900 180"
        width="140"
        height="28"
        aria-hidden="true"
      >
        <text x="30" y="135" font-family="'Instrument Serif', 'Iowan Old Style', Georgia, serif" font-size="140" font-style="italic" fill="#1a1814">B</text>
        <text x="118" y="130" font-family="'Instrument Serif', 'Iowan Old Style', Georgia, serif" font-size="118" fill="#1a1814">rowserMan</text>
      </svg>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a href="/">Writing</a>
      <a href="/about/">About</a>
      <a href="/rss.xml" class="site-nav__rss" aria-label="RSS feed">RSS</a>
      <a href={PRODUCT_URL} class="site-nav__product">
        browserman.run <span aria-hidden="true">→</span>
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(120%) blur(6px);
    background: rgba(245, 241, 232, 0.85);
  }

  .site-header__inner {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--ink-1);
    flex: 0 0 auto;
  }

  .brand:hover { color: var(--ink-1); }

  .brand__wordmark {
    display: block;
    width: auto;
    height: 28px;
    max-width: 100%;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 1.8rem;
  }

  .site-nav a {
    font-family: var(--sans);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--ink-2);
    text-decoration: none;
    transition: color 120ms var(--ease);
  }

  .site-nav a:hover { color: var(--ink-1); }

  .site-nav__rss {
    font-family: var(--mono) !important;
    font-size: 0.72rem !important;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3) !important;
  }

  .site-nav__product {
    color: var(--amber-deep) !important;
    font-weight: 600 !important;
  }

  .site-nav__product:hover { color: var(--ink-1) !important; }

  @media (max-width: 640px) {
    .site-header__inner { padding: 0.8rem 1rem; }
    .brand__wordmark { height: 24px; }
    .site-nav { gap: 1rem; }
    .site-nav a:not(.site-nav__product) { display: none; }
  }
</style>
