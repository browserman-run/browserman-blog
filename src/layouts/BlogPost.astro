---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../lib/i18n';
import { getLocalizedArchiveUrl } from '../lib/i18n';
import { t } from '../i18n/ui';

type Props = CollectionEntry<'blog'>['data'] & {
  translationUrl?: string;
  alternates?: { lang: Lang | 'x-default'; url: string }[];
  canonicalUrl?: string;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  socialImage,
  lang = 'en',
  translationUrl,
  alternates = [],
  canonicalUrl,
} = Astro.props;

const fmt = (d: Date) => new Intl.DateTimeFormat(lang === 'zh' ? 'zh-CN' : 'en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
}).format(d);
---

<html lang={lang}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={socialImage ?? heroImage}
      lang={lang}
      canonicalUrl={canonicalUrl}
      alternates={alternates}
    />
  </head>

  <body>
    <Header lang={lang} translationUrl={translationUrl} />

    <main>
      <article class="post">
        <header class="post__header">
          <div class="post__meta">
            <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
            {updatedDate && (
              <>
                <span aria-hidden="true">·</span>
                <span>{t(lang, 'updated')} {fmt(updatedDate)}</span>
              </>
            )}
          </div>

          <h1 class="post__title">{title}</h1>
          <p class="post__dek">{description}</p>
        </header>

        {heroImage && (
          <figure class="post__hero">
            <img src={heroImage.src} alt="" width={heroImage.width} height={heroImage.height} />
          </figure>
        )}

        <div class="post__body prose">
          <slot />
        </div>

        <footer class="post__footer">
          <a href={getLocalizedArchiveUrl(lang)} class="post__back">
            <span aria-hidden="true">←</span> {t(lang, 'allWriting')}
          </a>
        </footer>
      </article>
    </main>

    <Footer />
  </body>
</html>

<style>
  .post {
    max-width: var(--prose);
    margin: 0 auto;
    padding: 4rem 1.5rem 2rem;
  }

  .post__header {
    margin-bottom: 2.5rem;
  }

  .post__meta {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 1.5rem;
  }

  .post__title {
    font-family: var(--serif);
    font-size: clamp(2.4rem, 5.4vw, 3.8rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink-1);
    margin: 0 0 1rem;
  }

  .post__dek {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.35rem;
    line-height: 1.4;
    color: var(--ink-2);
    margin: 0;
    max-width: 60ch;
  }

  .post__hero {
    margin: 0 0 2.5rem;
  }

  .post__hero img {
    width: 100%;
    max-width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .post__footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }

  .post__back {
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink-2);
    text-decoration: none;
  }

  .post__back:hover { color: var(--amber-deep); }

  html:lang(zh) .post__title {
    font-family: var(--sans);
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  html:lang(zh) .post__dek {
    font-family: var(--sans);
    font-style: normal;
    line-height: 1.65;
  }

  @media (max-width: 720px) {
    .post { padding: 2.5rem 1rem 2rem; }
  }
</style>
