---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<html lang="en">
  <head>
    <BaseHead title={`Writing — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>

  <body>
    <Header />

    <main>
      <section class="archive-head">
        <p class="archive-head__kicker mono">Archive</p>
        <h1 class="archive-head__title">All writing from BrowserMan.</h1>
      </section>

      <section class="archive-feed">
        {posts.length ? (
          posts.map((post, index) => <PostCard post={post} featured={index === 0} />)
        ) : (
          <p class="archive-empty">Nothing published yet.</p>
        )}
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .archive-head,
  .archive-feed {
    max-width: var(--wide);
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .archive-head {
    padding-top: 4rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--rule);
  }

  .archive-head__kicker {
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber-deep);
    margin: 0 0 1rem;
  }

  .archive-head__title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.05;
    margin: 0;
  }

  .archive-feed {
    padding-top: 2.5rem;
    padding-bottom: 4rem;
  }

  .archive-empty {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--ink-3);
    padding: 3rem 0;
  }

  @media (max-width: 720px) {
    .archive-head,
    .archive-feed {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .archive-head {
      padding-top: 3rem;
      padding-bottom: 1.5rem;
    }
  }
</style>
