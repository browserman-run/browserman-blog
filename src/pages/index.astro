---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = posts[0];
const recent = posts.slice(1, 4);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
        gap: 2rem;
        align-items: end;
        padding: 2rem 0 1rem;
      }
      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-size: 0.75rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgb(var(--gray));
        margin-bottom: 1rem;
      }
      .eyebrow::before {
        content: '';
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 999px;
        background: var(--accent);
      }
      h1 {
        font-size: clamp(2.8rem, 8vw, 5.2rem);
        line-height: 0.95;
        letter-spacing: -0.03em;
        margin-bottom: 1rem;
      }
      .hero p {
        max-width: 42rem;
        color: rgb(var(--gray-dark));
        font-size: 1.05rem;
      }
      .hero-card {
        background: white;
        border: 1px solid rgba(var(--gray), 0.18);
        border-radius: 1rem;
        padding: 1.25rem;
        box-shadow: 0 12px 30px rgba(var(--gray), 0.08);
      }
      .hero-card h2 {
        font-size: 1.15rem;
        margin-bottom: 0.65rem;
      }
      .hero-card p {
        font-size: 0.98rem;
        margin: 0;
        color: rgb(var(--gray-dark));
      }
      .hero-links {
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
        margin-top: 1.25rem;
      }
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0.75rem 1rem;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 600;
      }
      .button.primary {
        background: var(--accent);
        color: white;
      }
      .button.secondary {
        border: 1px solid rgba(var(--gray), 0.22);
        color: rgb(var(--black));
        background: white;
      }
      .section-head {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        margin: 2.5rem 0 1rem;
      }
      .section-head h2 {
        margin: 0;
      }
      .muted {
        color: rgb(var(--gray));
      }
      .featured,
      .recent-grid article {
        background: white;
        border: 1px solid rgba(var(--gray), 0.18);
        border-radius: 1rem;
        padding: 1.25rem;
        box-shadow: 0 12px 30px rgba(var(--gray), 0.08);
      }
      .featured-title,
      .recent-title {
        text-decoration: none;
        color: rgb(var(--black));
      }
      .featured-title h3,
      .recent-title h3 {
        margin-bottom: 0.4rem;
      }
      .meta {
        font-size: 0.92rem;
        color: rgb(var(--gray));
        margin-bottom: 0.8rem;
      }
      .recent-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }
      .empty-state {
        border: 1px dashed rgba(var(--gray), 0.28);
        border-radius: 1rem;
        padding: 1.25rem;
        color: rgb(var(--gray));
      }
      @media (max-width: 900px) {
        .hero,
        .recent-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <div>
          <div class="eyebrow">BrowserMan writing</div>
          <h1>Notes from building browser automation that real agents can actually use.</h1>
          <p>
            This is where BrowserMan will publish product updates, design decisions, onboarding changes,
            launch notes, and practical writing about browser automation.
          </p>
          <div class="hero-links">
            <a class="button primary" href="/blog">Read posts</a>
            <a class="button secondary" href="https://browserman.run">Visit BrowserMan</a>
          </div>
        </div>
        <aside class="hero-card">
          <h2>What belongs here</h2>
          <p>
            Product updates. Design rationale. Setup changes. Experiments. Hard-won lessons from making
            browser access legible, scoped, and actually useful for AI agents.
          </p>
        </aside>
      </section>

      <section>
        <div class="section-head">
          <div>
            <h2>Latest post</h2>
            <p class="muted">Start with the newest writing from the BrowserMan team.</p>
          </div>
        </div>
        {featured ? (
          <article class="featured">
            <div class="meta"><FormattedDate date={featured.data.pubDate} /></div>
            <a class="featured-title" href={`/blog/${featured.id}/`}>
              <h3>{featured.data.title}</h3>
            </a>
            <p>{featured.data.description}</p>
          </article>
        ) : (
          <div class="empty-state">No posts yet. The blog skeleton is live and ready for the first article.</div>
        )}
      </section>

      <section>
        <div class="section-head">
          <div>
            <h2>Recent posts</h2>
            <p class="muted">A lightweight archive for future product and writing cadence.</p>
          </div>
          <a href="/blog">View all posts</a>
        </div>
        {recent.length ? (
          <div class="recent-grid">
            {recent.map((post) => (
              <article>
                <div class="meta"><FormattedDate date={post.data.pubDate} /></div>
                <a class="recent-title" href={`/blog/${post.id}/`}>
                  <h3>{post.data.title}</h3>
                </a>
                <p>{post.data.description}</p>
              </article>
            ))}
          </div>
        ) : (
          <div class="empty-state">Add more posts under src/content/blog/ to populate the archive.</div>
        )}
      </section>
    </main>
    <Footer />
  </body>
</html>
