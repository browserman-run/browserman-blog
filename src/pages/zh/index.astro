---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_TITLE, SITE_URL } from '../../consts';
import { t } from '../../i18n/ui';

const lang = 'zh';
const description = '关于 AI agent、真实浏览器工作流、BrowserMan 产品更新和实践经验的中文文章。';
const posts = (await getCollection('blog', ({ data }) => data.lang === lang)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const [featured, ...rest] = posts;
---

<html lang={lang}>
  <head>
    <BaseHead
      title={`${SITE_TITLE} 中文`}
      description={description}
      lang={lang}
      canonicalUrl={SITE_URL + '/zh/'}
      alternates={[
        { lang: 'en', url: SITE_URL + '/' },
        { lang: 'zh', url: SITE_URL + '/zh/' },
        { lang: 'x-default', url: SITE_URL + '/' },
      ]}
    />
  </head>

  <body>
    <Header lang={lang} translationUrl="/" />
    <main>
      <section class="hero">
        <div class="hero__inner">
          <p class="hero__kicker mono">{t(lang, 'heroKicker')}</p>
          <h1 class="hero__title">{t(lang, 'heroTitle')}</h1>
          <p class="hero__lede">{t(lang, 'heroLede')}</p>
        </div>
      </section>
      <section class="feed">
        <div class="feed__head">
          <h2 class="mono feed__label">{t(lang, 'latest')}</h2>
          <span class="feed__count mono">{posts.length} {t(lang, 'posts')}</span>
        </div>
        {featured && <PostCard post={featured} featured />}
        {rest.map((post) => <PostCard post={post} />)}
        {posts.length === 0 && <p class="feed__empty">{t(lang, 'empty')}</p>}
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .hero { max-width: var(--wide); margin: 0 auto; padding: 4.25rem 1.5rem 2.75rem; border-bottom: 1px solid var(--rule); }
  .hero__inner { max-width: 58ch; }
  .hero__kicker { font-family: var(--mono); font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--amber-deep); margin: 0 0 1.2rem; }
  .hero__title { font-family: var(--sans); font-size: clamp(2.2rem, 5vw, 3.6rem); line-height: 1.12; letter-spacing: -0.03em; color: var(--ink-1); margin: 0 0 1rem; max-width: 15ch; }
  .hero__lede { font-family: var(--sans); font-size: 1.16rem; line-height: 1.65; color: var(--ink-2); margin: 0; max-width: 44ch; }
  .feed { max-width: var(--wide); margin: 0 auto; padding: 3rem 1.5rem 4rem; }
  .feed__head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1rem; }
  .feed__label, .feed__count { font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-3); font-weight: 500; margin: 0; }
  .feed__empty { font-family: var(--sans); font-size: 1.2rem; color: var(--ink-3); text-align: center; padding: 4rem 0; }
  @media (max-width: 720px) { .hero { padding: 3rem 1rem 2rem; } .feed { padding: 2rem 1rem 3rem; } }
</style>
