---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PostCard from '../../../components/PostCard.astro';
import { SITE_TITLE, SITE_URL } from '../../../consts';
import { t } from '../../../i18n/ui';

const lang = 'zh';
const description = 'BrowserMan 中文文章归档。';
const posts = (await getCollection('blog', ({ data }) => data.lang === lang)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<html lang={lang}>
  <head>
    <BaseHead
      title={`文章 — ${SITE_TITLE}`}
      description={description}
      lang={lang}
      canonicalUrl={SITE_URL + '/zh/blog/'}
      alternates={[
        { lang: 'en', url: SITE_URL + '/blog/' },
        { lang: 'zh', url: SITE_URL + '/zh/blog/' },
        { lang: 'x-default', url: SITE_URL + '/blog/' },
      ]}
    />
  </head>
  <body>
    <Header lang={lang} translationUrl="/blog/" />
    <main>
      <section class="archive-head">
        <p class="archive-head__kicker mono">{t(lang, 'archive')}</p>
        <h1 class="archive-head__title">{t(lang, 'archiveTitle')}</h1>
      </section>
      <section class="archive-feed">
        {posts.length ? posts.map((post, index) => <PostCard post={post} featured={index === 0} />) : <p class="archive-empty">{t(lang, 'archiveEmpty')}</p>}
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .archive-head, .archive-feed { max-width: var(--wide); margin: 0 auto; padding-left: 1.5rem; padding-right: 1.5rem; }
  .archive-head { padding-top: 4rem; padding-bottom: 2rem; border-bottom: 1px solid var(--rule); }
  .archive-head__kicker { font-family: var(--mono); font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--amber-deep); margin: 0 0 1rem; }
  .archive-head__title { font-family: var(--sans); font-size: clamp(2.1rem, 5vw, 3.4rem); line-height: 1.12; margin: 0; }
  .archive-feed { padding-top: 2.5rem; padding-bottom: 4rem; }
  .archive-empty { font-family: var(--sans); font-size: 1.2rem; color: var(--ink-3); padding: 3rem 0; }
  @media (max-width: 720px) { .archive-head, .archive-feed { padding-left: 1rem; padding-right: 1rem; } .archive-head { padding-top: 3rem; padding-bottom: 1.5rem; } }
</style>
